<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="40dp"
            android:background="@color/white">

            <!-- Back Button + Title Row -->

            <!-- Instructor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/back_button"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:src="@drawable/back_button_1" />

                <TextView
                    android:id="@+id/tvCourseTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:text="Data Base Management System"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvCourseInstructor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dr. Dinesh Patil • DBMS 301"
                android:textSize="13sp"
                android:textColor="@color/text_gray"
                android:layout_marginTop="4dp"
                android:layout_marginStart="44dp"/>

            <!-- Semester Tag -->
            <TextView
                android:id="@+id/tvCourseSemester"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sem - 04 2026"
                android:textSize="12sp"
                android:textColor="@color/tag_red_text"
                android:background="@drawable/tag_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="44dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Scrollable Tab Menu -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/white"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- General Tab -->
            <LinearLayout
                android:id="@+id/tabGeneral"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_selected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="General"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Syllabus Tab -->
            <LinearLayout
                android:id="@+id/tabSyllabus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_unselected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvSyllabus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Syllabus"
                    android:textSize="15sp"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Assignments Tab -->
            <LinearLayout
                android:id="@+id/tabAssignments"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_unselected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvAssignments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assignments"
                    android:textSize="15sp"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Quizzes Tab -->
            <LinearLayout
                android:id="@+id/tabQuizzes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_unselected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvQuizzes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quizzes"
                    android:textSize="15sp"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Activities Tab -->
            <LinearLayout
                android:id="@+id/tabActivities"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_unselected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvActivities"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grades"
                    android:textSize="15sp"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Projects Tab -->
            <LinearLayout
                android:id="@+id/tabProjects"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/tab_unselected_bg"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvProjects"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects"
                    android:textSize="15sp"
                    android:textColor="@color/black"/>
            </LinearLayout>


        </LinearLayout>
    </ScrollView>

    <!-- Fragment Content Area -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>