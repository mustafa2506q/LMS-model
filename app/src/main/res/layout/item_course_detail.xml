<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/white">

        <!-- Course Icon -->
        <TextView
            android:id="@+id/tvCourseIcon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="📖"
            android:textSize="26sp"
            android:gravity="center"
            android:background="@drawable/course_icon_bg"
            android:layout_marginEnd="14dp"/>

        <!-- Course Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name + Tag Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvCourseName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Calculus I"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>

                <TextView
                    android:id="@+id/tvSemesterTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_bg"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="3dp"
                    android:text="Sem - 04  2026"
                    android:textColor="@color/red_primary"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Instructor -->
            <TextView
                android:id="@+id/tvInstructor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:text="Dr. Dinesh Patil"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <!-- Code + Students Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Course Code Tag -->
                <TextView
                    android:id="@+id/tvCourseCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MATH 101"
                    android:textSize="11sp"
                    android:textColor="@color/text_gray"
                    android:background="@drawable/code_tag_bg"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="12dp"/>

                <!-- Students -->
                <TextView
                    android:id="@+id/tvStudents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 45 students"
                    android:textSize="11sp"
                    android:textColor="@color/text_gray"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>