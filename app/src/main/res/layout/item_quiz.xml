<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white">

        <!-- Status Tag -->
        <TextView
            android:id="@+id/tvQuizStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available Now"
            android:textSize="12sp"
            android:textColor="#27AE60"
            android:background="@drawable/status_submitted_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- Quiz Title -->
        <TextView
            android:id="@+id/tvQuizTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quiz 3: Limits"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <!-- Questions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❓"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvQuestions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 questions"
                android:textSize="13sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

        <!-- Time Limit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvTimeLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 min time limit"
                android:textSize="13sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

        <!-- Attempts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvAttempts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 attempt allowed"
                android:textSize="13sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

        <!-- Due Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvQuizDueDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due: Mar 18, 2026"
                android:textSize="13sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>