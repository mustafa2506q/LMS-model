<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="40dp"
            android:layout_marginTop="20dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="16dp"/>

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/tab_row_bg"
                android:padding="3dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tabMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Month"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/tab_selected_bg"/>

                <TextView
                    android:id="@+id/tabWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Week"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:gravity="center"
                    android:background="@drawable/tab_unselected_bg"/>

                <TextView
                    android:id="@+id/tabAgenda"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Agenda"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:gravity="center"
                    android:background="@drawable/tab_unselected_bg"/>

            </LinearLayout>

            <!-- ===== MONTH VIEW ===== -->
            <LinearLayout
                android:id="@+id/calendarCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Calendar Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/white"
                        android:padding="12dp">

                        <!-- Month Navigation -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/btnPrevMonth"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="‹"
                                android:textSize="26sp"
                                android:textColor="@color/text_gray"
                                android:gravity="center"/>

                            <TextView
                                android:id="@+id/tvMonthYear"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="March 2026"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:gravity="center"/>

                            <TextView
                                android:id="@+id/btnNextMonth"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="›"
                                android:textSize="26sp"
                                android:textColor="@color/text_gray"
                                android:gravity="center"/>

                        </LinearLayout>

                        <!-- Day Headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:layout_marginBottom="4dp">

                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Sun" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Mon" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Tue" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Wed" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Thu" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Fri" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>
                            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Sat" android:textSize="11sp" android:textColor="@color/text_gray" android:gravity="center" android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- Calendar Grid -->
                        <LinearLayout
                            android:id="@+id/calendarGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Upcoming Events Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Upcoming Events"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Events"
                        android:textSize="13sp"
                        android:textColor="@color/red_primary"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Event Card 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="@color/red_primary"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Assignment"
                                    android:textSize="11sp"
                                    android:textColor="@color/red_primary"
                                    android:background="@drawable/status_due_soon_bg"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mar 15"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Math Assignment 3"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Calculus I"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Event Card 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="#E67E22"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Assignment"
                                    android:textSize="11sp"
                                    android:textColor="@color/red_primary"
                                    android:background="@drawable/status_due_soon_bg"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mar 17"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_gray"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Essay on Shakespeare"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="English Literature"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Event Card 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="#2980B9"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Quiz"
                                    android:textSize="11sp"
                                    android:textColor="#2980B9"
                                    android:background="@drawable/status_upcoming_bg"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mar 18"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_gray"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Calculus Quiz 3: Limits"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Calculus I"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Event Card 4 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="@color/red_primary"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Assignment"
                                    android:textSize="11sp"
                                    android:textColor="@color/red_primary"
                                    android:background="@drawable/status_due_soon_bg"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mar 20"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_gray"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Lab Report 2"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Physics"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Event Card 5 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="#27AE60"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Quiz"
                                    android:textSize="11sp"
                                    android:textColor="#27AE60"
                                    android:background="@drawable/status_submitted_bg"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mar 22"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_gray"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Programming Quiz 2"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Computer Science"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
            <!-- ===== END MONTH VIEW ===== -->

            <!-- ===== WEEK VIEW ===== -->
            <FrameLayout
                android:id="@+id/weekViewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/weekContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </FrameLayout>
            <!-- ===== END WEEK VIEW ===== -->

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navOverview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⊞"
                android:textSize="22sp"
                android:textColor="@color/text_gray"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overview"
                android:textSize="11sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="22sp"
                android:textColor="@color/red_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:textSize="11sp"
                android:textColor="@color/red_primary"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProjects"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁"
                android:textSize="22sp"
                android:textColor="@color/text_gray"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Projects"
                android:textSize="11sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="22sp"
                android:textColor="@color/text_gray"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="@color/text_gray"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>